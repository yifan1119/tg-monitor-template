# Caddy 反代配置 — 给 Web 后台套 HTTPS(为了 Google OAuth)
#
# 启用方式:
#   1. 在 .env 加一行: PUBLIC_DOMAIN=76-13-219-163.nip.io
#      (没域名的话用 nip.io;有域名就填你的域名比如 tg.example.com)
#   2. docker compose -p tg-demo --profile https up -d caddy
#   3. 等 30 秒,Caddy 会自动从 Let's Encrypt 申请证书
#   4. 之后访问 https://YOUR_DOMAIN/  → 自动反代到 Web 容器的 5001
#
# Google OAuth 重定向 URI 改用:
#   https://YOUR_DOMAIN/api/oauth/callback   (注意:HTTPS + 不带端口)
#
# 前提:VPS 80 / 443 端口对外开放(Let's Encrypt HTTP-01 challenge 用)

{$PUBLIC_DOMAIN} {
    # v3.1.3.2 改用显式容器名 tg-web-__COMPANY_NAME__:5001 防 DNS 撞车。
    # 历史「web:5001」别名问题:Caddy 容器一旦接进多个 docker network(共用 Caddy
    # 给同 VPS 第二个部门反代),每个 network 里都有名为「web」的容器 → Docker DNS
    # 返回任意一个 → 部门 A 子域被路由到部门 B 的后端(2026-05-13 线上复现)。
    # __COMPANY_NAME__ 由 install.sh / update.sh 替换成实际部门名。详见 ADR-0044。
    reverse_proxy {$WEB_UPSTREAM:tg-web-__COMPANY_NAME__:5001} {
        # 透传真实 host,Flask 的 request.host_url 才会拿到外部 host(给 OAuth redirect 用)
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    # Caddy 默认会自动 enable Let's Encrypt;失败的话日志会说原因
    encode gzip
}

# v3.1.5 (2026-05-18): 同 VPS 多 dept 共用 Caddy 模式 — 其他 dept 的 site block
# 写在 conf.d/<COMPANY>.caddy 各自独立文件(.gitignored,update.sh git reset 不冲)。
# enable_https.sh 自动写到这里,而非 append 主 Caddyfile(踩过 5+ 次的坑根治)。
# 详见 ADR-0049。
import conf.d/*.caddy
