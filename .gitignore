# 实例专属机密 — 永远不进 git
.env
.env.*
!.env.example
oauth_token.json
google_oauth_token.json
token.json
credentials.json
client_secret*.json

# 运行时数据
sessions/*
!sessions/.gitkeep
data/*
!data/.gitkeep
*.session
*.session-journal
data.db
data.db-*

# Python
__pycache__/
*.pyc
venv/

# IDE
.vscode/
.idea/
.DS_Store

# update.sh / rollback.sh 运行时记录(每台机不一样,不进 git)
.last_commit
