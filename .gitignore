# 实例专属机密 — 永远不进 git
.env
.env.*
!.env.example
oauth_token.json
google_oauth_token.json
token.json
credentials.json
client_secret*.json

# 运行时数据
sessions/*
!sessions/.gitkeep
data/*
!data/.gitkeep
*.session
*.session-journal
data.db
data.db-*

# Python
__pycache__/
*.pyc
venv/

# IDE
.vscode/
.idea/
.DS_Store

# update.sh / rollback.sh 运行时记录(每台机不一样,不进 git)
.last_commit

# 本地实验备份(不进 git)
.dashboard-backup-*
.metrics-backup/

# Claude 专案本地设置(每台机权限白名单、私有备注,不进 git)
.claude/settings.local.json
.claude/sessions/
.claude/memory/
.claude/private-*.md
.claude/*.local.md
